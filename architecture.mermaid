flowchart LR
    A["MCP Client<br/>stdio / SSE / streamable-http"] --> B["FastMCP Server<br/>create_server()"]
    B --> C["Tool Registration<br/>register_tools()"]
    C --> D["Tool Handler<br/>handle_send_invoice / ..."]
    D --> E["run_tool()"]
    E --> F["RequestContextResolver"]
    E --> G["Pydantic Input Model"]
    E --> H["Capability Check"]

    F --> I["StandaloneRequestContextResolver"]
    F --> J["PlatformRequestContextResolver"]

    J --> K["auth_context_var + LocalAccessRegistry"]
    K --> L["workspace_id / user_id / client_id / capabilities"]

    E --> M["Backend"]

    M --> N["StandaloneBackend"]
    N --> O["ksef2 SDK Authenticated Client"]
    O --> P["KSeF API"]

    M --> Q["PlatformBackend"]
    Q --> R["POST /internal/tools/*"]
    R --> S["ksef2-platform"]
    S --> T["ksef2 SDK"]
    T --> P